# Clé API OpenAI pour la génération d'images DALL-E 3
# Récupère-la sur https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Optionnel : modèle DALL-E à utiliser
DALLE_MODEL=dall-e-3

# Optionnel : taille des images générées (1024x1024, 1792x1024, 1024x1792)
DALLE_SIZE=1792x1024

# Optionnel : qualité (standard ou hd — hd coûte 2x plus cher)
DALLE_QUALITY=standard

# Optionnel : ton revenu net mensuel par défaut (pour skip la question)
DEFAULT_REVENU_NET=2200

# Optionnel : ton apport par défaut
DEFAULT_APPORT=13000

# Optionnel : dossier de sortie des rapports
OUTPUT_DIR=~/Documents/immo-analyzer
